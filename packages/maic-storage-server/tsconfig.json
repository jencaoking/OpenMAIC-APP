{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "verbatimModuleSyntax": true,
    "paths": {
      "@openmaic/storage": ["../@openmaic/storage/dist/index.js"],
      "@openmaic/dsl": ["../@openmaic/dsl/dist/index.js"],
      "@openmaic/storage-types": ["../@openmaic/storage-types/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"]
}