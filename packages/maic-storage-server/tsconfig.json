{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "verbatimModuleSyntax": true,
    "paths": {
      "@openmaic/storage": ["../@openmaic/storage/src/index.ts"],
      "@openmaic/dsl": ["../@openmaic/dsl/src/index.ts"],
      "@openmaic/storage-types": ["../@openmaic/storage-types/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}