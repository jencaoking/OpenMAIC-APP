{
  "name": "@openmaic/storage-types",
  "version": "0.1.0",
  "description": "Pure TypeScript type contracts for OpenMAIC storage layer. Zero runtime dependencies. Safe for Expo/Metro bundler.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --outDir dist --declaration"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/THU-MAIC/OpenMAIC",
    "directory": "packages/@openmaic/storage-types"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}