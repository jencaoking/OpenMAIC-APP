{
  "name": "@openmaic/core-engine",
  "version": "0.1.0",
  "description": "Cross-platform DSL rendering engine for OpenMAIC. Zero runtime dependencies on react-native or react-dom. Uses Adapter Pattern for platform-agnostic UI rendering.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --emitDeclarationOnly --outDir dist"
  },
  "peerDependencies": {
    "@types/react": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/THU-MAIC/OpenMAIC",
    "directory": "packages/@openmaic/core-engine"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}