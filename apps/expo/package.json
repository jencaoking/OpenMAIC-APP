{
  "name": "@openmaic/expo",
  "version": "0.1.0",
  "main": "index.ts",
  "dependencies": {
    "@openmaic/core-engine": "workspace:*",
    "@openmaic/storage-types": "workspace:*",
    "@ronradtke/react-native-markdown-display": "^9.0.3",
    "@sentry/react-native": "^6.10.0",
    "expo": "~57.0.7",
    "expo-av": "^16.0.8",
    "expo-background-fetch": "~14.0.0",
    "expo-battery": "~9.0.0",
    "expo-build-properties": "~1.0.0",
    "expo-camera": "~17.0.0",
    "expo-constants": "~17.0.0",
    "expo-file-system": "~19.0.0",
    "expo-haptics": "^57.0.1",
    "expo-image-manipulator": "~14.0.0",
    "expo-image-picker": "~17.0.0",
    "expo-notifications": "~0.31.0",
    "expo-secure-store": "~14.0.0",
    "expo-sqlite": "^57.0.1",
    "expo-splash-screen": "~0.30.0",
    "expo-status-bar": "~57.0.1",
    "expo-task-manager": "~14.0.0",
    "expo-updates": "~0.28.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^3.1.0",
    "react-native-netinfo": "^1.1.0",
    "react-native-reanimated": "^4.5.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "eas:build:dev": "eas build --profile development --platform all",
    "eas:build:preview": "eas build --profile preview --platform all",
    "eas:build:prod": "eas build --profile production --platform all",
    "eas:submit:ios": "eas submit --platform ios",
    "eas:submit:android": "eas submit --platform android",
    "eas:update": "eas update --branch production --message",
    "eas:update:rollback": "eas update --rollback --branch production"
  },
  "private": true
}
